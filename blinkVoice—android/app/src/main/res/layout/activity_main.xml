<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay for drawing landmarks -->
    <com.example.eyeblinkdetect.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status panel at top -->
    <LinearLayout
        android:id="@+id/statusPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FPS: --"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBlinkCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blinks: 0"
            android:textColor="#FFD700"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Eye state display at bottom -->
    <LinearLayout
        android:id="@+id/eyeStatePanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Blink status large text -->
        <TextView
            android:id="@+id/tvBlinkStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EYES OPEN"
            android:textColor="#00FF88"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- EAR values -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvLeftEar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Left EAR: 0.00"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvRightEar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Right EAR: 0.00"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Inference / load time -->
        <TextView
            android:id="@+id/tvInferenceMs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Infer: --ms | Load: --ms"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Power stats -->
        <TextView
            android:id="@+id/tvPower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bat: --%"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="2dp" />

        <!-- EAR threshold label + SeekBar -->
        <TextView
            android:id="@+id/tvEarThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EAR threshold: 0.22"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="6dp" />

        <SeekBar
            android:id="@+id/seekBarEar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvAutoEarThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Auto EAR: DEFAULT | close&lt;0.220 open&gt;0.250"
            android:textColor="#00D1FF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSdkCapture"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="测试 SDK 调起接口"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvSdkCaptureResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="SDK result: --"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
